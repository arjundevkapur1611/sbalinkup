# Database
DATABASE_URL="postgresql://username:password@localhost:5432/sba_linkup"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key"

# JWT Secret
JWT_SECRET="your-jwt-secret-key"

# File Upload (AWS S3 or similar)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_BUCKET_NAME="sba-linkup-uploads"
AWS_REGION="us-east-1"

# Email Service (for password reset, notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="noreply@sbalinkup.com"

# WebSocket/Real-time (if using external service)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="us2"

# Admin Configuration
ADMIN_EMAIL="arjundevkapur@gmail.com"